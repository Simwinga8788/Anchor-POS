<Window x:Class="SurfPOS.Desktop.Views.CashEndDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="End Shift" 
        Height="250" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                  Text="Ending Cash Amount"
                  FontSize="20"
                  FontWeight="Bold"
                  Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Enter the total amount of cash in the drawer at the end of your shift:"
                      TextWrapping="Wrap"
                      Margin="0,0,0,15"
                      Opacity="0.7"/>
            
            <TextBox x:Name="CashAmountTextBox"
                    materialDesign:HintAssist.Hint="Cash Amount"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    FontSize="16"
                    Text="0.00"/>
        </StackPanel>

        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">
            <Button Content="END SHIFT"
                   Style="{StaticResource MaterialDesignRaisedButton}"
                   Width="120"
                   Height="40"
                   Margin="0,0,10,0"
                   Click="EndButton_Click"/>
            <Button Content="CANCEL"
                   Style="{StaticResource MaterialDesignOutlinedButton}"
                   Width="100"
                   Height="40"
                   Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="SurfPOS.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings" 
        Height="600" 
        Width="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                  Text="Application Settings"
                  FontSize="28"
                  FontWeight="Bold"
                  Margin="0,0,0,30"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Theme Settings -->
                <TextBlock Text="Theme Configuration"
                          FontSize="20"
                          FontWeight="SemiBold"
                          Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Dark Mode" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ToggleButton x:Name="DarkModeToggle"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="DarkModeToggle_Click"/>
                </StackPanel>

                <ComboBox x:Name="ColorComboBox"
                         materialDesign:HintAssist.Hint="Select Accent Color"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         Margin="0,0,0,30"
                         FontSize="14"
                         SelectionChanged="ColorComboBox_SelectionChanged">
                    <ComboBoxItem Content="Blue" Tag="Blue" IsSelected="True"/>
                    <ComboBoxItem Content="Light Blue" Tag="LightBlue"/>
                    <ComboBoxItem Content="Cyan" Tag="Cyan"/>
                    <ComboBoxItem Content="Teal" Tag="Teal"/>
                    <ComboBoxItem Content="Green" Tag="Green"/>
                    <ComboBoxItem Content="Lime" Tag="Lime"/>
                    <ComboBoxItem Content="Yellow" Tag="Yellow"/>
                    <ComboBoxItem Content="Amber" Tag="Amber"/>
                    <ComboBoxItem Content="Orange" Tag="Orange"/>
                    <ComboBoxItem Content="Deep Orange" Tag="DeepOrange"/>
                    <ComboBoxItem Content="Red" Tag="Red"/>
                    <ComboBoxItem Content="Pink" Tag="Pink"/>
                    <ComboBoxItem Content="Deep Purple" Tag="DeepPurple"/>
                    <ComboBoxItem Content="Indigo" Tag="Indigo"/>
                </ComboBox>
                <TextBlock Text="Email Configuration"
                          FontSize="20"
                          FontWeight="SemiBold"
                          Margin="0,0,0,15"/>
                
                <TextBox x:Name="AdminEmailTextBox"
                        materialDesign:HintAssist.Hint="Admin Email Address"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"
                        FontSize="14"/>

                <TextBox x:Name="SmtpHostTextBox"
                        materialDesign:HintAssist.Hint="SMTP Host (e.g., smtp.gmail.com)"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"
                        FontSize="14"/>

                <TextBox x:Name="SmtpPortTextBox"
                        materialDesign:HintAssist.Hint="SMTP Port (e.g., 587)"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"
                        FontSize="14"/>

                <TextBox x:Name="SmtpUsernameTextBox"
                        materialDesign:HintAssist.Hint="SMTP Username"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"
                        FontSize="14"/>

                <PasswordBox x:Name="SmtpPasswordBox"
                            materialDesign:HintAssist.Hint="SMTP Password"
                            Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                            Margin="0,0,0,15"
                            FontSize="14"/>

                <TextBox x:Name="FromEmailTextBox"
                        materialDesign:HintAssist.Hint="From Email Address"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,30"
                        FontSize="14"/>

                <!-- WhatsApp Settings -->
                <TextBlock Text="WhatsApp Configuration"
                          FontSize="20"
                          FontWeight="SemiBold"
                          Margin="0,20,0,15"/>

                <TextBox x:Name="AdminPhoneTextBox"
                        materialDesign:HintAssist.Hint="Admin Phone Numbers (comma separated, e.g. 2609712.., 2609612..)"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"
                        FontSize="14"/>

                <TextBlock Text="Note: WhatsApp will open in your browser with the report details. You'll need to manually attach the file."
                          TextWrapping="Wrap"
                          Opacity="0.6"
                          FontSize="12"
                          Margin="0,0,0,30"/>

                <!-- Store Settings -->
                <TextBlock Text="Store Information"
                          FontSize="20"
                          FontWeight="SemiBold"
                          Margin="0,20,0,15"/>

                <TextBox x:Name="StoreNameTextBox"
                        materialDesign:HintAssist.Hint="Store Name"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"
                        FontSize="14"/>

                <TextBox x:Name="StoreAddressTextBox"
                        materialDesign:HintAssist.Hint="Store Address"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"
                        FontSize="14"/>


                <TextBox x:Name="StorePhoneTextBox"
                        materialDesign:HintAssist.Hint="Store Phone"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,30"
                        FontSize="14"/>

                <!-- Printer Settings -->
                <TextBlock Text="Printer Configuration"
                          FontSize="20"
                          FontWeight="SemiBold"
                          Margin="0,20,0,15"/>

                <ComboBox x:Name="PrinterComboBox"
                         materialDesign:HintAssist.Hint="Select Receipt Printer"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         Margin="0,0,0,15"
                         FontSize="14"
                         SelectionChanged="PrinterComboBox_SelectionChanged"/>

                <ComboBox x:Name="PaperSizeComboBox"
                         materialDesign:HintAssist.Hint="Paper Size"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         Margin="0,0,0,15"
                         FontSize="14">
                    <ComboBoxItem Content="80mm (Standard)" IsSelected="True"/>
                    <ComboBoxItem Content="58mm (Mobile/Bluetooth)"/>
                </ComboBox>

                <ComboBox x:Name="DensityComboBox"
                         materialDesign:HintAssist.Hint="Print Density"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         Margin="0,0,0,20"
                         FontSize="14">
                    <ComboBoxItem Content="Standard / 50%" Tag="Normal" IsSelected="True"/>
                    <ComboBoxItem Content="Medium / 75% (Double Strike)" Tag="Medium"/>
                    <ComboBoxItem Content="High / 100% (Bold)" Tag="Bold"/>
                </ComboBox>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="TEST PRINTER"
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Width="150"
                           Height="40"
                           FontSize="14"
                           Margin="0,0,15,0"
                           Click="TestPrinterButton_Click"/>
                    
                    <Button Content="REFRESH PRINTERS"
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Width="180"
                           Height="40"
                           FontSize="14"
                           Click="RefreshPrintersButton_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Enable Printing" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ToggleButton x:Name="PrintingEnabledToggle"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  IsChecked="True"/>
                </StackPanel>

                <TextBlock x:Name="PrinterStatusTextBlock"
                           Text="✓ Ready to print"
                           Foreground="Green"
                           FontSize="14"
                           Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,30,0,0">
            <Button Content="TEST EMAIL"
                   Style="{StaticResource MaterialDesignOutlinedButton}"
                   Width="150"
                   Height="45"
                   FontSize="14"
                   Margin="0,0,15,0"
                   Click="TestEmailButton_Click"/>
            <Button Content="SAVE SETTINGS"
                   Style="{StaticResource MaterialDesignRaisedButton}"
                   Width="150"
                   Height="45"
                   FontSize="14"
                   Margin="0,0,15,0"
                   Click="SaveButton_Click"/>
            <Button Content="CLOSE"
                   Style="{StaticResource MaterialDesignOutlinedButton}"
                   Width="120"
                   Height="45"
                   FontSize="14"
                   Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="SurfPOS.Desktop.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="User Management" 
        Height="600" 
        Width="800"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="20,15">
            <Grid>
                <TextBlock Text="👥 User Management" 
                          FontSize="24" 
                          FontWeight="Bold"
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <Button Content="CLOSE"
                       Style="{StaticResource MaterialDesignFlatButton}"
                       Foreground="White"
                       HorizontalAlignment="Right"
                       Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Users List -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="10"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                              Text="System Users"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Margin="0,0,0,15"/>

                    <DataGrid x:Name="UsersDataGrid"
                             Grid.Row="1"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             IsReadOnly="True"
                             SelectionMode="Single"
                             SelectionChanged="UsersDataGrid_SelectionChanged"
                             Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- User Form -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="10"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="User Details"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,20"/>

                        <!-- Username -->
                        <TextBox x:Name="UsernameTextBox"
                                materialDesign:HintAssist.Hint="Username"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Margin="0,0,0,15"/>

                        <!-- Password (only for new users) -->
                        <PasswordBox x:Name="PasswordBox"
                                    materialDesign:HintAssist.Hint="Password"
                                    Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                    Margin="0,0,0,15"/>

                        <!-- Role -->
                        <ComboBox x:Name="RoleComboBox"
                                 materialDesign:HintAssist.Hint="Role"
                                 Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                 Margin="0,0,0,15">
                            <ComboBoxItem Content="Admin" Tag="0"/>
                            <ComboBoxItem Content="Salesperson" Tag="1" IsSelected="True"/>
                        </ComboBox>

                        <!-- Active Status -->
                        <CheckBox x:Name="IsActiveCheckBox"
                                 Content="Active"
                                 IsChecked="True"
                                 Margin="0,0,0,20"/>

                        <!-- Action Buttons -->
                        <StackPanel>
                            <Button x:Name="AddButton"
                                   Content="ADD NEW USER"
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Margin="0,0,0,10"
                                   Click="AddButton_Click"/>
                            <Button x:Name="UpdateButton"
                                   Content="UPDATE USER"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Margin="0,0,0,10"
                                   IsEnabled="False"
                                   Click="UpdateButton_Click"/>
                            <Button x:Name="ChangePasswordButton"
                                   Content="CHANGE PASSWORD"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Margin="0,0,0,10"
                                   IsEnabled="False"
                                   Click="ChangePasswordButton_Click"/>
                            <Button x:Name="DeactivateButton"
                                   Content="DEACTIVATE USER"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   IsEnabled="False"
                                   Click="DeactivateButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>

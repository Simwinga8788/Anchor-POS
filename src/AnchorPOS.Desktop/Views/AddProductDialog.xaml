<Window x:Class="SurfPOS.Desktop.Views.AddProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add New Product" 
        Height="600" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                  Text="Add New Product"
                  FontSize="24"
                  FontWeight="Bold"
                  Margin="0,0,0,30"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Barcode Section -->
                <TextBlock Text="Barcode"
                          FontSize="14"
                          FontWeight="SemiBold"
                          Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="BarcodeTextBox"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="Scan or enter barcode"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            KeyDown="BarcodeTextBox_KeyDown"/>
                    
                    <Button Grid.Column="2"
                           Content="GENERATE"
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Click="GenerateBarcodeButton_Click"
                           ToolTip="Generate SURF barcode for products without barcode"/>
                </Grid>
                
                <TextBlock x:Name="BarcodeStatusText"
                          FontSize="12"
                          Margin="0,-10,0,15"
                          Foreground="Gray"/>

                <!-- Name -->
                <TextBox x:Name="NameTextBox"
                        materialDesign:HintAssist.Hint="Product Name *"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"/>

                <!-- Category -->
                <ComboBox x:Name="CategoryComboBox"
                         materialDesign:HintAssist.Hint="Category *"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         Margin="0,0,0,15">
                    <ComboBoxItem Content="Hair Products"/>
                    <ComboBoxItem Content="Wigs"/>
                    <ComboBoxItem Content="Perfumes"/>
                    <ComboBoxItem Content="Makeup"/>
                    <ComboBoxItem Content="Clothes"/>
                    <ComboBoxItem Content="General" IsSelected="True"/>
                </ComboBox>

                <!-- Price -->
                <TextBox x:Name="PriceTextBox"
                        materialDesign:HintAssist.Hint="Selling Price *"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"/>

                <!-- Cost Price -->
                <TextBox x:Name="CostPriceTextBox"
                        materialDesign:HintAssist.Hint="Cost Price *"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,15"/>

                <!-- Stock Quantity -->
                <TextBox x:Name="StockQuantityTextBox"
                        materialDesign:HintAssist.Hint="Initial Stock Quantity *"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Text="0"
                        Margin="0,0,0,15"/>

                <!-- Low Stock Threshold -->
                <TextBox x:Name="LowStockThresholdTextBox"
                        materialDesign:HintAssist.Hint="Low Stock Threshold *"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Text="5"
                        Margin="0,0,0,15"/>

                <TextBlock Text="* Scan existing barcode or click GENERATE for new products"
                          FontSize="12"
                          Opacity="0.7"
                          Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                   Content="CANCEL"
                   Style="{StaticResource MaterialDesignOutlinedButton}"
                   Height="45"
                   Click="CancelButton_Click"/>

            <Button Grid.Column="2"
                   Content="ADD PRODUCT"
                   Style="{StaticResource MaterialDesignRaisedButton}"
                   Height="45"
                   Click="AddButton_Click"/>
        </Grid>
    </Grid>
</Window>

<Window x:Class="SurfPOS.Desktop.Views.ProductManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Product Management" 
        Height="900" 
        Width="1600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="20,15">
            <Grid>
                <TextBlock Text="📦 Product Management" 
                          FontSize="24" 
                          FontWeight="Bold"
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <Button Content="CLOSE"
                       Style="{StaticResource MaterialDesignFlatButton}"
                       Foreground="White"
                       HorizontalAlignment="Right"
                       Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Products List -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="10"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search -->
                    <TextBox x:Name="SearchBox"
                            Grid.Row="0"
                            materialDesign:HintAssist.Hint="Search products..."
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Margin="0,0,0,15"
                            TextChanged="SearchBox_TextChanged"/>

                    <!-- Filter -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="CategoryFilterComboBox" IsEditable="True"
                                 materialDesign:HintAssist.Hint="Filter by Category"
                                 Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                 Width="200"
                                 SelectionChanged="CategoryFilterComboBox_SelectionChanged"/>
                        
                        <CheckBox x:Name="LowStockCheckBox"
                                 Content="Low Stock Only"
                                 Margin="20,0,0,0"
                                 VerticalAlignment="Center"
                                 Checked="LowStockCheckBox_Changed"
                                 Unchecked="LowStockCheckBox_Changed"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid x:Name="ProductsDataGrid"
                             Grid.Row="2"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             IsReadOnly="True"
                             SelectionMode="Extended"
                             SelectionChanged="ProductsDataGrid_SelectionChanged"
                             Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Width="50" 
                                                   Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   ElementStyle="{StaticResource MaterialDesignDataGridCheckBoxColumnStyle}"
                                                   EditingElementStyle="{StaticResource MaterialDesignDataGridCheckBoxColumnEditingStyle}">
                                <DataGridCheckBoxColumn.Header>
                                    <CheckBox x:Name="SelectAllCheckBox" 
                                             Click="SelectAllCheckBox_Click"
                                             ToolTip="Select/Deselect All"/>
                                </DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}K{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice, StringFormat={}K{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="80"/>
                            <DataGridTextColumn Header="Threshold" Binding="{Binding LowStockThreshold}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
                        <Button x:Name="AddButton"
                               Content="ADD NEW"
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Margin="0,0,10,0"
                               Click="AddButton_Click"/>
                        <Button x:Name="DownloadTemplateButton"
                               Content="DOWNLOAD TEMPLATE"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Margin="0,0,10,0"
                               Click="DownloadTemplateButton_Click"/>
                        <Button x:Name="ImportButton"
                               Content="IMPORT EXCEL"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Margin="0,0,10,0"
                               Click="ImportButton_Click"/>
                        <Button x:Name="ExportButton"
                               Content="EXPORT EXCEL"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Margin="0,0,10,0"
                               Click="ExportButton_Click"/>
                        <Button x:Name="BatchPrintButton"
                               Content="PRINT SELECTED LABELS"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Click="BatchPrintButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Product Details / Edit Form -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="10"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="EditPanel" IsEnabled="False">
                        <TextBlock Text="Product Details"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,20"/>

                        <!-- Barcode -->
                        <TextBox x:Name="BarcodeTextBox"
                                materialDesign:HintAssist.Hint="Barcode"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Margin="0,0,0,15"
                                IsReadOnly="True"/>

                        <!-- Name -->
                        <TextBox x:Name="NameTextBox"
                                materialDesign:HintAssist.Hint="Product Name"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Margin="0,0,0,15"/>

                        <!-- Category -->
                        <ComboBox x:Name="CategoryComboBox" IsEditable="True"
                                 materialDesign:HintAssist.Hint="Category"
                                 Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                 Margin="0,0,0,15"/>

                        <!-- Price -->
                        <TextBox x:Name="PriceTextBox"
                                materialDesign:HintAssist.Hint="Selling Price"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Margin="0,0,0,15"/>

                        <!-- Cost Price -->
                        <TextBox x:Name="CostPriceTextBox"
                                materialDesign:HintAssist.Hint="Cost Price"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Margin="0,0,0,15"/>

                        <!-- Stock Quantity -->
                        <TextBox x:Name="StockQuantityTextBox"
                                materialDesign:HintAssist.Hint="Stock Quantity"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Margin="0,0,0,15"/>

                        <!-- Low Stock Threshold -->
                        <TextBox x:Name="LowStockThresholdTextBox"
                                materialDesign:HintAssist.Hint="Low Stock Threshold"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                Margin="0,0,0,20"/>

                        <!-- Action Buttons -->
                        <StackPanel>
                            <Button x:Name="SaveButton"
                                   Content="SAVE CHANGES"
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Margin="0,0,0,10"
                                   Click="SaveButton_Click"/>
                            <Button x:Name="DeleteButton"
                                   Content="DELETE PRODUCT"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Margin="0,0,0,10"
                                   Click="DeleteButton_Click"/>
                            <Button x:Name="RestockButton"
                                   Content="RESTOCK"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Margin="0,0,0,10"
                                   Click="RestockButton_Click"/>
                            <Button x:Name="PrintLabelButton"
                                   Content="PRINT LABEL"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Click="PrintLabelButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>

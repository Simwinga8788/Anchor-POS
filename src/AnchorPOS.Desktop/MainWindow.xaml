<Window x:Class="SurfPOS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Anchor POS - Point of Sale" 
        Height="800" 
        Width="1400"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" 
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="StoreNameTextBlock" Text="ANCHOR POS" 
                              FontSize="24" 
                              FontWeight="Bold"
                              Foreground="White"
                              VerticalAlignment="Center"/>
                    <TextBlock x:Name="UserInfoTextBlock"
                              FontSize="14" 
                              Foreground="White"
                              Opacity="0.8"
                              VerticalAlignment="Center"
                              Margin="30,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ProductsButton"
                           Content="PRODUCTS"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           Margin="0,0,10,0"
                           Click="ProductsButton_Click"/>
                    <Button x:Name="ReportsButton"
                           Content="REPORTS"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           Margin="0,0,10,0"
                           Click="ReportsButton_Click"/>
                    <Button x:Name="UsersButton"
                           Content="USERS"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           Margin="0,0,10,0"
                           Click="UsersButton_Click"/>
                    <Button x:Name="SettingsButton"
                           Content="SETTINGS"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           Margin="0,0,10,0"
                           Click="SettingsButton_Click"/>
                    <Button x:Name="LogoutButton"
                           Content="LOGOUT"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Product Search & Selection -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="10"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Box -->
                    <TextBox x:Name="BarcodeSearchBox"
                            Grid.Row="0"
                            materialDesign:HintAssist.Hint="Scan or Enter Barcode / Product Name"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            FontSize="18"
                            Padding="15"
                            Margin="0,0,0,20"
                            KeyDown="BarcodeSearchBox_KeyDown"/>

                    <TextBlock Grid.Row="1"
                              Text="Available Products"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Margin="0,0,0,10"/>

                    <!-- Products List -->
                    <DataGrid x:Name="ProductsDataGrid"
                             Grid.Row="2"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             IsReadOnly="True"
                             SelectionMode="Single"
                             MouseDoubleClick="ProductsDataGrid_MouseDoubleClick"
                             Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}K{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Panel - Shopping Cart -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="10"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                              Text="Shopping Cart"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Margin="0,0,0,10"/>

                    <!-- Cart Items -->
                    <ListView x:Name="CartListView"
                             Grid.Row="1"
                             Margin="0,0,0,20">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource MaterialDesignPaper}" 
                                        CornerRadius="8" 
                                        Margin="0,3" 
                                        Padding="8"
                                        Effect="{DynamicResource MaterialDesignShadowDepth1}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Product Info -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <TextBlock Text="{Binding ProductName}"
                                                      FontWeight="Bold"
                                                      FontSize="13"
                                                      TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat={}K{0:N2}}"
                                                      FontSize="11"
                                                      Opacity="0.6"/>
                                        </StackPanel>

                                        <!-- Quantity Controls -->
                                        <Border Grid.Column="1" 
                                                Background="{DynamicResource MaterialDesignDivider}" 
                                                CornerRadius="12" 
                                                Padding="2"
                                                Margin="0,0,5,0"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                                                        Width="22" Height="22"
                                                        Content="-"
                                                        Padding="0"
                                                        FontSize="12"
                                                        Tag="{Binding ProductId}"
                                                        Click="DecreaseQty_Click"/>
                                                
                                                <TextBlock Text="{Binding Quantity}"
                                                          FontWeight="Bold"
                                                          FontSize="12"
                                                          MinWidth="20"
                                                          TextAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="3,0"/>

                                                <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                                                        Width="22" Height="22"
                                                        Content="+"
                                                        Padding="0"
                                                        FontSize="12"
                                                        Tag="{Binding ProductId}"
                                                        Click="IncreaseQty_Click"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Total Price -->
                                        <TextBlock Grid.Column="2" 
                                                  Text="{Binding TotalText}"
                                                  FontWeight="Bold"
                                                  FontSize="13"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,5,0"
                                                  Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                                        <!-- Remove Button -->
                                        <Button Grid.Column="3"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Width="28" Height="28"
                                                Padding="0"
                                                ToolTip="Remove Item"
                                                Tag="{Binding ProductId}"
                                                Click="RemoveCartItem_Click">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18" Foreground="#E53935"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Total -->
                    <Border Grid.Row="2"
                           Background="{DynamicResource MaterialDesign.Brush.Primary}"
                           Padding="15"
                           CornerRadius="5"
                           Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="TOTAL"
                                      FontSize="16"
                                      FontWeight="Bold"
                                      Foreground="White"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalTextBlock"
                                      Text="K0.00"
                                      FontSize="24"
                                      FontWeight="Bold"
                                      Foreground="White"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Payment Method -->
                    <ComboBox x:Name="PaymentMethodComboBox"
                             Grid.Row="3"
                             materialDesign:HintAssist.Hint="Payment Method"
                             Style="{StaticResource MaterialDesignOutlinedComboBox}"
                             Margin="0,0,0,15">
                        <ComboBoxItem Content="Cash" IsSelected="True"/>
                        <ComboBoxItem Content="Card"/>
                        <ComboBoxItem Content="Mobile Money"/>
                    </ComboBox>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ClearButton"
                               Grid.Column="0"
                               Content="CLEAR"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Height="50"
                               Click="ClearButton_Click"/>

                        <Button x:Name="CheckoutButton"
                               Grid.Column="2"
                               Content="CHECKOUT"
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Height="50"
                               FontWeight="Bold"
                               Click="CheckoutButton_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
